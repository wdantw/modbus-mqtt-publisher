[Service]
WorkingDirectory=/opt/modbus-mqtt-publisher
ExecStart=/opt/modbus-mqtt-publisher/MudbusMqttPublisher.Server
Restart=always
# Restart service after 10 seconds if the dotnet service crashes:
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=modbus-mqtt-publisher
User=root
Environment=ASPNETCORE_ENVIRONMENT=production
Environment=MODBUS_MQTT_PUBLISHER_USERCONFIG=/etc/modbus-mqtt-publisher.json

[Install]
WantedBy=multi-user.target
